# Copy to .env and fill in values from Supabase Dashboard → Project Settings → Database

# App runtime — Transaction pooler (port 6543, pgbouncer=true)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Prisma migrations — Session pooler (port 5432, NO pgbouncer) OR legacy direct host
# Prefer session pooler (same host as DATABASE_URL, port 5432):
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# Legacy direct host (db.<ref>.supabase.co) may fail with ENOTFOUND on some networks — use session pooler above.
# OpenRouter — chat translation (AR/EN) and contact-sharing filter (Qwen 3.5 Flash)

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.5-flash-02-23
OPENROUTER_SITE_URL=https://your-production-domain.com
OPENROUTER_APP_NAME=E-Tashleh Marketplace

# App URLs
FRONTEND_URL=https://e-tshaleh.net

# JWT session length — customers/vendors: 7d (WhatsApp deep links); staff: 1d
JWT_EXPIRES_IN=7d
JWT_EXPIRES_IN_ADMIN=1d

# Resend Email OTP
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=E-Tshaleh <noreply@e-tashleh.net>
# Public site URL for email links/logo (defaults to https://e-tashleh.net when FRONTEND_URL is localhost)
RESEND_SITE_URL=https://e-tashleh.net
# Optional external logo URL. Leave unset to embed logo from backend/assets/logo-email.png (fastest).
# RESEND_LOGO_URL=https://e-tashleh.net/logo.png

# Widers WhatsApp (Phase 1+)
WIDERS_ENABLED=false
WIDERS_API_TOKEN=
WIDERS_API_BASE_URL=https://apps.widers.net
WIDERS_TEST_PHONE=+9665xxxxxxxx
# utility = OTP via Utility template until Meta Authentication is approved
WIDERS_OTP_MODE=utility
# OTP requires WIDERS_ENABLED=true with valid credentials. In non-production, failed sends log OTP to console only.

# Nomo economic registry PDF (view-only via GET /public/documents/nomo-registry)
# Default path: backend/assets/nomo-registry.pdf
# NOMO_REGISTRY_PDF_PATH=
# Meta/Widers webhook verify token — callback: https://YOUR_API/widers/webhook
WIDERS_WEBHOOK_SECRET=
